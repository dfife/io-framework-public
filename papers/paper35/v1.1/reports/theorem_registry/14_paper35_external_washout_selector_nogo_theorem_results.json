{
  "mission": "Prove that no universal standard thermal-leptogenesis washout theorem can fix kappa_f from source data alone.",
  "source_class": {
    "status": "conditional / exact external washout class",
    "assumptions": [
      "standard unflavored decay + inverse-decay Boltzmann system",
      "same source data and same decay parameter K",
      "admissible change only in the heavy-neutrino initial abundance"
    ],
    "equations": {
      "dN1_dz": "-D(z,K) [N1 - N1_eq(z)]",
      "dNBL_dz": "-eps1 D(z,K) [N1 - N1_eq(z)] - W(z,K) N_B-L",
      "D": "K z K1(z) / K2(z)",
      "W": "(1/4) K z^3 K1(z)",
      "N1_eq": "(1/2) z^2 K2(z)"
    }
  },
  "theorem_1_initial_condition_counterexample": {
    "status": "verified / explicit external counterexample",
    "witnesses": {
